<?xml version="1.0" ?>
<robot name="exo_arm_right" xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:macro name="exo_arm_right" params="prefix mount_x mount_y mount_z mount_roll mount_pitch mount_yaw">
<xacro:property name="arm_base_link" value="${prefix + 'base_link' if prefix != '' else 'base_link'}"/>

<xacro:if value="${prefix != ''}">
  <joint name="${prefix}mount_joint" type="fixed">
    <origin xyz="${mount_x} ${mount_y} ${mount_z}" rpy="${mount_roll} ${mount_pitch} ${mount_yaw}"/>
    <parent link="base_link"/>
    <child link="${arm_base_link}"/>
  </joint>
</xacro:if>

<link name="${arm_base_link}">
  <inertial>
    <origin xyz="-0.06548033529530813 3.6162664937364756e-05 -0.024681013869616315" rpy="0 0 0"/>
    <mass value="0.071076"/>
    <inertia ixx="0.00057" iyy="0.001116" izz="0.000764" ixy="-3e-06" iyz="-6.9e-05" ixz="-0.000381"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/right/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/right/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="${prefix}component_1">
  <inertial>
    <origin xyz="0.020078154117980904 -0.07680678655412938 0.00015979036369085514" rpy="0 0 0"/>
    <mass value="0.103407"/>
    <inertia ixx="0.0015" iyy="0.001127" izz="0.002243" ixy="0.000743" iyz="2.8e-05" ixz="-5.2e-05"/>
  </inertial>
  <visual>
    <origin xyz="0.096353 0.0 0.038143" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/right/Right_Component_1_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0.096353 0.0 0.038143" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/right/Right_Component_1_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="${prefix}motor_1">
  <inertial>
    <origin xyz="-0.028657149296548154 -8.058668921841178e-05 -0.000810066210235709" rpy="0 0 0"/>
    <mass value="0.33655768070512687"/>
    <inertia ixx="0.000158" iyy="0.000208" izz="0.000206" ixy="-0.0" iyz="0.0" ixz="-7e-06"/>
  </inertial>
  <visual>
    <origin xyz="0.093353 0.0 0.038143" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/right/Right_Motor_1_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0.093353 0.0 0.038143" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/right/Right_Motor_1_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="${prefix}motor_2">
  <inertial>
    <origin xyz="0.0008094176294007934 -0.02565689899779973 8.018840696268764e-05" rpy="0 0 0"/>
    <mass value="0.33655768070512687"/>
    <inertia ixx="0.000206" iyy="0.000158" izz="0.000208" ixy="7e-06" iyz="0.0" ixz="0.0"/>
  </inertial>
  <visual>
    <origin xyz="0.009353 0.107 0.038143" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/right/Right_Motor_2_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0.009353 0.107 0.038143" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/right/Right_Motor_2_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="${prefix}component_2">
  <inertial>
    <origin xyz="1.7395672801560902e-05 0.006512704300103006 -0.06684120565439672" rpy="0 0 0"/>
    <mass value="0.069014"/>
    <inertia ixx="0.001293" iyy="0.001346" izz="6.3e-05" ixy="-0.0" iyz="1e-06" ixz="0.0"/>
  </inertial>
  <visual>
    <origin xyz="0.009353 0.104 0.038143" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/right/Right_Component_2_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0.009353 0.104 0.038143" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/right/Right_Component_2_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="${prefix}component_3">
  <inertial>
    <origin xyz="-0.00624485437452308 0.023063684861781966 -0.09933410970644764" rpy="0 0 0"/>
    <mass value="0.276754"/>
    <inertia ixx="0.009623" iyy="0.00994" izz="0.001914" ixy="0.0003" iyz="-0.00023" ixz="-0.000599"/>
  </inertial>
  <visual>
    <origin xyz="0.009341 0.092 0.083713" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/right/Right_Component_3_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0.009341 0.092 0.083713" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/right/Right_Component_3_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="${prefix}motor_3">
  <inertial>
    <origin xyz="0.0005239633876655348 -0.028343595073468772 0.004273928835601515" rpy="0 0 0"/>
    <mass value="0.33655768070512687"/>
    <inertia ixx="0.000208" iyy="0.000158" izz="0.000207" ixy="4e-06" iyz="3e-06" ixz="-0.0"/>
  </inertial>
  <visual>
    <origin xyz="0.007241 0.10198 0.328465" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/right/Right_Motor_3_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0.007241 0.10198 0.328465" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/right/Right_Motor_3_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="${prefix}component_4">
  <inertial>
    <origin xyz="-0.0048723202311687815 -0.005488292975653827 -0.08462064279554748" rpy="0 0 0"/>
    <mass value="0.070944"/>
    <inertia ixx="0.001503" iyy="0.00162" izz="0.000292" ixy="8.6e-05" iyz="-7.5e-05" ixz="-3.2e-05"/>
  </inertial>
  <visual>
    <origin xyz="0.00724 0.104936 0.327953" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/right/Right_Component_4_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0.00724 0.104936 0.327953" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/right/Right_Component_4_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<joint name="${prefix}fixed_1" type="fixed">
  <origin xyz="-0.003 0.0 0.0" rpy="0 0 0"/>
  <parent link="${prefix}motor_1"/>
  <child link="${prefix}component_1"/>
</joint>

<joint name="${prefix}revolute_1" type="revolute">
  <origin xyz="-0.093353 0.0 -0.038143" rpy="0 0 0"/>
  <parent link="${arm_base_link}"/>
  <child link="${prefix}motor_1"/>
  <axis xyz="-1.0 -0.0 0.0"/>
  <dynamics damping="0.012" friction="0.1184"/>
  <limit lower="0" upper="1.919" effort="20" velocity="11"/>
</joint>

<joint name="${prefix}fixed_2" type="fixed">
  <origin xyz="0.087 -0.107 0.0" rpy="0 0 0"/>
  <parent link="${prefix}component_1"/>
  <child link="${prefix}motor_2"/>
</joint>

<joint name="${prefix}revolute_2" type="revolute">
  <origin xyz="0.0 0.003 0.0" rpy="0 0 0"/>
  <parent link="${prefix}motor_2"/>
  <child link="${prefix}component_2"/>
  <axis xyz="0.0 -1.0 0.0"/>
  <dynamics damping="0.012" friction="0.1184"/>
  <limit lower="-0.56" upper="2.793" effort="20" velocity="11"/>
</joint>

<joint name="${prefix}fixed_3" type="fixed">
  <origin xyz="1.2e-05 0.012 -0.04557" rpy="0 0 0"/>
  <parent link="${prefix}component_2"/>
  <child link="${prefix}component_3"/>
</joint>

<joint name="${prefix}revolute_3" type="revolute">
  <origin xyz="0.0021 -0.00998 -0.244752" rpy="0 0 0"/>
  <parent link="${prefix}component_3"/>
  <child link="${prefix}motor_3"/>
  <axis xyz="7.9e-05 -0.985338 0.170613"/>
  <dynamics damping="0.012" friction="0.1184"/>
  <limit lower="0" upper="2.094" effort="20" velocity="11"/>
</joint>

<joint name="${prefix}fixed_4" type="fixed">
  <origin xyz="1e-06 -0.002956 0.000512" rpy="0 0 0"/>
  <parent link="${prefix}motor_3"/>
  <child link="${prefix}component_4"/>
</joint>

</xacro:macro>
</robot>