<?xml version="1.0" ?>
<robot name="exo_arm_right" xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:macro name="exo_arm_right" params="prefix mount_x mount_y mount_z mount_roll mount_pitch mount_yaw joint_dynamics:=false
  m_extra_component_1:=0 m_extra_component_2:=0 m_extra_component_3:=0 m_extra_component_4:=0 m_payload:=0
  extra_mass_radius:=0.05">
<xacro:property name="arm_base_link" value="${prefix + 'base_link' if prefix != '' else 'base_link'}"/>
<!-- Each extra mass is modeled as a uniform solid sphere centered at the link's
     existing COM; contribution to ixx/iyy/izz is (2/5)*m*r^2. Off-diagonals are
     unaffected because the sphere is symmetric about the same COM. -->
<xacro:property name="_di_c1" value="${0.4 * m_extra_component_1 * extra_mass_radius * extra_mass_radius}"/>
<xacro:property name="_di_c2" value="${0.4 * m_extra_component_2 * extra_mass_radius * extra_mass_radius}"/>
<xacro:property name="_di_c3" value="${0.4 * m_extra_component_3 * extra_mass_radius * extra_mass_radius}"/>
<xacro:property name="_di_c4" value="${0.4 * (m_extra_component_4 + m_payload) * extra_mass_radius * extra_mass_radius}"/>

<xacro:if value="${prefix != ''}">
  <joint name="${prefix}mount_joint" type="fixed">
    <origin xyz="${mount_x} ${mount_y} ${mount_z}" rpy="${mount_roll} ${mount_pitch} ${mount_yaw}"/>
    <parent link="base_link"/>
    <child link="${arm_base_link}"/>
  </joint>
</xacro:if>

<link name="${arm_base_link}">
  <inertial>
    <origin xyz="-0.06508828909321891 0.0016392932839860918 -0.029106794021422928" rpy="0 0 0"/>
    <mass value="0.071076"/>
    <inertia ixx="0.000208" iyy="0.00032" izz="0.000185" ixy="8e-06" iyz="3e-06" ixz="-0.000104"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/right/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <xacro:if value="${joint_dynamics}">
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/right/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
  </xacro:if>
</link>

<link name="${prefix}component_1">
  <inertial>
    <origin xyz="0.020078156586478324 -0.002520887276899919 0.07676564491860602" rpy="0 0 0"/>
    <mass value="${0.10340048966459635 + m_extra_component_1}"/>
    <inertia ixx="${0.000203 + _di_c1}" iyy="${0.000303 + _di_c1}" izz="${0.000152 + _di_c1}" ixy="-4e-06" iyz="1e-06" ixz="-0.0001"/>
  </inertial>
  <visual>
    <origin xyz="0.097353 0.00061 0.063136" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/right/Right_Component_1_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <xacro:if value="${joint_dynamics}">
  <collision>
    <origin xyz="0.097353 0.00061 0.063136" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/right/Right_Component_1_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
  </xacro:if>
</link>

<link name="${prefix}motor_1">
  <inertial>
    <origin xyz="-0.028657146735079228 -0.0008124469950160578 5.2337020642223564e-05" rpy="0 0 0"/>
    <mass value="0.33655768070512676"/>
    <inertia ixx="0.000158" iyy="0.000206" izz="0.000208" ixy="-7e-06" iyz="-0.0" ixz="0.0"/>
  </inertial>
  <visual>
    <origin xyz="0.094353 0.00061 0.063136" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/right/Right_Motor_1_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <xacro:if value="${joint_dynamics}">
  <collision>
    <origin xyz="0.094353 0.00061 0.063136" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/right/Right_Motor_1_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
  </xacro:if>
</link>

<link name="${prefix}motor_2">
  <inertial>
    <origin xyz="0.0008094200168279157 -0.0008145820388575867 0.02564395698733552" rpy="0 0 0"/>
    <mass value="0.33655768070512676"/>
    <inertia ixx="0.000206" iyy="0.000208" izz="0.000158" ixy="0.0" iyz="1e-06" ixz="-7e-06"/>
  </inertial>
  <visual>
    <origin xyz="0.010353 0.004345 -0.043799" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/right/Right_Motor_2_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <xacro:if value="${joint_dynamics}">
  <collision>
    <origin xyz="0.010353 0.004345 -0.043799" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/right/Right_Motor_2_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
  </xacro:if>
</link>

<link name="${prefix}component_2">
  <inertial>
    <origin xyz="0.02170967506266145 0.06340564193577251 -0.004302798150324916" rpy="0 0 0"/>
    <mass value="${0.06901401423488361 + m_extra_component_2}"/>
    <inertia ixx="${0.000157 + _di_c2}" iyy="${2.6e-05 + _di_c2}" izz="${0.000182 + _di_c2}" ixy="-5.1e-05" iyz="-5e-06" ixz="-2e-06"/>
  </inertial>
  <visual>
    <origin xyz="0.010353 0.00424 -0.040801" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/right/Right_Component_2_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <xacro:if value="${joint_dynamics}">
  <collision>
    <origin xyz="0.010353 0.00424 -0.040801" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/right/Right_Component_2_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
  </xacro:if>
</link>

<link name="${prefix}component_3">
  <inertial>
    <origin xyz="0.0362007475571462 0.08488733536574525 -0.02097339196773956" rpy="0 0 0"/>
    <mass value="${0.2572924347231441 + m_extra_component_3}"/>
    <inertia ixx="${0.001177 + _di_c3}" iyy="${0.00037 + _di_c3}" izz="${0.001416 + _di_c3}" ixy="-0.0004" iyz="-2.1e-05" ixz="3.6e-05"/>
  </inertial>
  <visual>
    <origin xyz="-0.008346 -0.050211 -0.041702" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/right/Right_Component_3_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <xacro:if value="${joint_dynamics}">
  <collision>
    <origin xyz="-0.008346 -0.050211 -0.041702" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/right/Right_Component_3_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
  </xacro:if>
</link>

<link name="${prefix}motor_3">
  <inertial>
    <origin xyz="0.00071319645679499 -0.0004566132738064721 0.028656360017304303" rpy="0 0 0"/>
    <mass value="0.33655768070512676"/>
    <inertia ixx="0.000207" iyy="0.000208" izz="0.000158" ixy="-0.0" iyz="-2e-06" ixz="-6e-06"/>
  </inertial>
  <visual>
    <origin xyz="-0.080242 -0.26481 -0.039283" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/right/Right_Motor_3_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <xacro:if value="${joint_dynamics}">
  <collision>
    <origin xyz="-0.080242 -0.26481 -0.039283" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/right/Right_Motor_3_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
  </xacro:if>
</link>

<link name="${prefix}component_4">
  <inertial>
    <origin xyz="-0.08441969431975782 -0.002715032580566934 -0.008979759026676165" rpy="0 0 0"/>
    <mass value="${0.07092471532503089 + m_extra_component_4 + m_payload}"/>
    <inertia ixx="${4.2e-05 + _di_c4}" iyy="${0.000201 + _di_c4}" izz="${0.000218 + _di_c4}" ixy="-1.2e-05" iyz="1e-05" ixz="-2.2e-05"/>
  </inertial>
  <visual>
    <origin xyz="-0.080247 -0.264713 -0.042282" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/right/Right_Component_4_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <xacro:if value="${joint_dynamics}">
  <collision>
    <origin xyz="-0.080247 -0.264713 -0.042282" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/right/Right_Component_4_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
  </xacro:if>
</link>

<joint name="${prefix}fixed_1" type="fixed">
  <origin xyz="-0.003 0.0 0.0" rpy="0 0 0"/>
  <parent link="${prefix}motor_1"/>
  <child link="${prefix}component_1"/>
</joint>

<joint name="${prefix}revolute_1" type="revolute">
  <origin xyz="-0.094353 -0.00061 -0.063136" rpy="0 0 0"/>
  <parent link="${arm_base_link}"/>
  <child link="${prefix}motor_1"/>
  <axis xyz="-1.0 -0.0 0.0"/>
  <xacro:if value="${joint_dynamics}">
  <dynamics damping="0.012" friction="0.1184"/>
  </xacro:if>
  <limit lower="-3.14" upper="0" effort="20" velocity="11"/>
</joint>

<joint name="${prefix}fixed_2" type="fixed">
  <origin xyz="0.087 -0.003735 0.106935" rpy="0 0 0"/>
  <parent link="${prefix}component_1"/>
  <child link="${prefix}motor_2"/>
</joint>

<joint name="${prefix}revolute_2" type="revolute">
  <origin xyz="0.0 0.000105 -0.002998" rpy="0 0 0"/>
  <parent link="${prefix}motor_2"/>
  <child link="${prefix}component_2"/>
  <axis xyz="0.0 -0.034899 0.999391"/>
  <xacro:if value="${joint_dynamics}">
  <dynamics damping="0.012" friction="0.1184"/>
  </xacro:if>
  <limit lower="-3.3" upper="0" effort="20" velocity="11"/>
</joint>

<joint name="${prefix}fixed_3" type="fixed">
  <origin xyz="0.018699 0.054451 0.000901" rpy="0 0 0"/>
  <parent link="${prefix}component_2"/>
  <child link="${prefix}component_3"/>
</joint>

<joint name="${prefix}revolute_3" type="revolute">
  <origin xyz="0.071896 0.214599 -0.002419" rpy="0 0 0"/>
  <parent link="${prefix}component_3"/>
  <child link="${prefix}motor_3"/>
  <axis xyz="0.001695 -0.032293 0.999477"/>
  <xacro:if value="${joint_dynamics}">
  <dynamics damping="0.012" friction="0.1184"/>
  </xacro:if>
  <limit lower="-2.08" upper="0" effort="20" velocity="11"/>
</joint>

<joint name="${prefix}fixed_4" type="fixed">
  <origin xyz="5e-06 -9.7e-05 0.002999" rpy="0 0 0"/>
  <parent link="${prefix}motor_3"/>
  <child link="${prefix}component_4"/>
</joint>

</xacro:macro>
</robot>
