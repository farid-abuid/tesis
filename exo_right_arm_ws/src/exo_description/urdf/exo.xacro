<?xml version="1.0" ?>
<robot name="exo" xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:arg name="hardware" default="real"/>
<xacro:arg name="controller_config" default="controllers_effort.yaml"/>
<!-- arms: right (default), left, or dual. Single-arm modes use unprefixed joints. -->
<xacro:arg name="arms" default="right"/>

<!-- Optional fixed mounts (base_link) for each arm in dual mode (meters, radians). -->
<xacro:arg name="right_mount_x" default="0"/>
<xacro:arg name="right_mount_y" default="-0.20"/>
<xacro:arg name="right_mount_z" default="0"/>
<xacro:arg name="right_mount_roll" default="0"/>
<xacro:arg name="right_mount_pitch" default="0"/>
<xacro:arg name="right_mount_yaw" default="0"/>
<xacro:arg name="left_mount_x" default="0"/>
<xacro:arg name="left_mount_y" default="0.20"/>
<xacro:arg name="left_mount_z" default="0"/>
<xacro:arg name="left_mount_roll" default="0"/>
<xacro:arg name="left_mount_pitch" default="0"/>
<xacro:arg name="left_mount_yaw" default="0"/>

<xacro:include filename="$(find exo_description)/urdf/materials.xacro" />
<xacro:include filename="$(find exo_description)/urdf/exo_arm_right.xacro" />
<xacro:include filename="$(find exo_description)/urdf/exo_arm_left.xacro" />

<link name="world"/>

<joint name="world_fixed" type="fixed">
  <parent link="world"/>
  <child link="base_link"/>
  <origin xyz="0 0 0.6" rpy="0 0 0"/>
</joint>

<xacro:if value="${xacro.arg('arms') == 'dual'}">
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.001"/>
      <inertia ixx="1e-06" iyy="1e-06" izz="1e-06" ixy="0" iyz="0" ixz="0"/>
    </inertial>
  </link>
</xacro:if>

<xacro:if value="${xacro.arg('arms') == 'dual'}">
  <xacro:exo_arm_right prefix="right_"
    mount_x="${xacro.arg('right_mount_x')}" mount_y="${xacro.arg('right_mount_y')}" mount_z="${xacro.arg('right_mount_z')}"
    mount_roll="${xacro.arg('right_mount_roll')}" mount_pitch="${xacro.arg('right_mount_pitch')}" mount_yaw="${xacro.arg('right_mount_yaw')}"/>
  <xacro:exo_arm_left prefix="left_"
    mount_x="${xacro.arg('left_mount_x')}" mount_y="${xacro.arg('left_mount_y')}" mount_z="${xacro.arg('left_mount_z')}"
    mount_roll="${xacro.arg('left_mount_roll')}" mount_pitch="${xacro.arg('left_mount_pitch')}" mount_yaw="${xacro.arg('left_mount_yaw')}"/>
</xacro:if>
<xacro:if value="${xacro.arg('arms') == 'right'}">
  <xacro:exo_arm_right prefix="" mount_x="0" mount_y="0" mount_z="0" mount_roll="0" mount_pitch="0" mount_yaw="0"/>
</xacro:if>
<xacro:if value="${xacro.arg('arms') == 'left'}">
  <xacro:exo_arm_left prefix="" mount_x="0" mount_y="0" mount_z="0" mount_roll="0" mount_pitch="0" mount_yaw="0"/>
</xacro:if>

<ros2_control name="exo_system" type="system">
  <hardware>

    <xacro:if value="${xacro.arg('hardware') == 'real'}">
      <plugin>exo_hardware/teensy_plugin</plugin>
        <param name="effort_stiction_comp_enabled">false</param>
        <xacro:if value="${xacro.arg('arms') == 'dual'}">
          <param name="motor_ids">1,2,3,4,5,6</param>
          <param name="joint_directions">1,-1,1,-1,1,-1</param>
          <param name="effort_stiction_tau_values">0.65,0.86,1.26,0.65,0.86,1.26</param>
          <param name="effort_stiction_slope_values">1, 1, 1, 1, 1, 1</param>
        </xacro:if>
        <xacro:if value="${xacro.arg('arms') == 'right'}">
          <param name="effort_stiction_tau_values">0.65,0.86,1.26</param>
          <param name="effort_stiction_slope_values">1, 1, 1</param>
        </xacro:if>
        <xacro:if value="${xacro.arg('arms') == 'left'}">
          <param name="motor_ids">4,5,6</param>
          <param name="joint_directions">-1,1,-1</param>
          <param name="effort_stiction_tau_values">0.65,0.86,1.26</param>
          <param name="effort_stiction_slope_values">1, 1, 1</param>
        </xacro:if>
    </xacro:if>

    <xacro:if value="${xacro.arg('hardware') == 'gazebo'}">
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </xacro:if>

  </hardware>

  <xacro:if value="${xacro.arg('arms') == 'dual'}">
    <joint name="right_revolute_1">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="right_revolute_2">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="right_revolute_3">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="left_revolute_1">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="left_revolute_2">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="left_revolute_3">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
  </xacro:if>
  <xacro:unless value="${xacro.arg('arms') == 'dual'}">
    <joint name="revolute_1">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="revolute_2">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="revolute_3">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
  </xacro:unless>

</ros2_control>

<xacro:if value="${xacro.arg('hardware') == 'gazebo'}">
  <xacro:include filename="$(find exo_description)/urdf/exo.gazebo"/>
</xacro:if>

</robot>
