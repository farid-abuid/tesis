<?xml version="1.0" ?>
<robot name="exo_arm_left" xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:macro name="exo_arm_left" params="prefix mount_x mount_y mount_z mount_roll mount_pitch mount_yaw">
<xacro:property name="arm_base_link" value="${prefix + 'base_link' if prefix != '' else 'base_link'}"/>

<xacro:if value="${prefix != ''}">
  <joint name="${prefix}mount_joint" type="fixed">
    <origin xyz="${mount_x} ${mount_y} ${mount_z}" rpy="${mount_roll} ${mount_pitch} ${mount_yaw}"/>
    <parent link="base_link"/>
    <child link="${arm_base_link}"/>
  </joint>
</xacro:if>

<link name="${arm_base_link}">
  <inertial>
    <origin xyz="-0.06548033561011322 -3.616267163486952e-05 -0.024681014225333156" rpy="0 0 0"/>
    <mass value="0.526364488337285"/>
    <inertia ixx="0.00057" iyy="0.001116" izz="0.000764" ixy="3e-06" iyz="6.9e-05" ixz="-0.000381"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/left/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/left/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="${prefix}motor_1">
  <inertial>
    <origin xyz="-0.028657149518970373 8.058698600191602e-05 -0.0008100661993833275" rpy="0 0 0"/>
    <mass value="0.33655768521614"/>
    <inertia ixx="0.000158" iyy="0.000208" izz="0.000206" ixy="0.0" iyz="-0.0" ixz="-7e-06"/>
  </inertial>
  <visual>
    <origin xyz="0.093353 -0.0 0.038143" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/left/Left_Motor_1_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0.093353 -0.0 0.038143" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/left/Left_Motor_1_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="${prefix}component_1">
  <inertial>
    <origin xyz="0.02007815411342466 0.07680678650680861 0.00015979042048477887" rpy="0 0 0"/>
    <mass value="0.7657489074365715"/>
    <inertia ixx="0.0015" iyy="0.001127" izz="0.002243" ixy="-0.000743" iyz="-2.8e-05" ixz="-5.2e-05"/>
  </inertial>
  <visual>
    <origin xyz="0.096353 -0.0 0.038143" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/left/Left_Component_1_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0.096353 -0.0 0.038143" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/left/Left_Component_1_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="${prefix}motor_2">
  <inertial>
    <origin xyz="0.0008094176185517183 0.025656899220221727 8.018870374155301e-05" rpy="0 0 0"/>
    <mass value="0.33655768521614"/>
    <inertia ixx="0.000206" iyy="0.000158" izz="0.000208" ixy="-7e-06" iyz="-0.0" ixz="0.0"/>
  </inertial>
  <visual>
    <origin xyz="0.009353 -0.107 0.038143" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/left/Left_Motor_2_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0.009353 -0.107 0.038143" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/left/Left_Motor_2_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="${prefix}component_2">
  <inertial>
    <origin xyz="1.739567280411962e-05 -0.0065127043001018264 -0.06684120565439666" rpy="0 0 0"/>
    <mass value="0.5110943635268609"/>
    <inertia ixx="0.001293" iyy="0.001346" izz="6.3e-05" ixy="0.0" iyz="-1e-06" ixz="0.0"/>
  </inertial>
  <visual>
    <origin xyz="0.009353 -0.104 0.038143" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/left/Left_Component_2_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0.009353 -0.104 0.038143" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/left/Left_Component_2_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="${prefix}component_3">
  <inertial>
    <origin xyz="-0.0062448498075838264 -0.023063684617812677 -0.09933411008225428" rpy="0 0 0"/>
    <mass value="2.049559404848652"/>
    <inertia ixx="0.009623" iyy="0.00994" izz="0.001914" ixy="-0.0003" iyz="0.00023" ixz="-0.000599"/>
  </inertial>
  <visual>
    <origin xyz="0.009341 -0.103 0.083713" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/left/Left_Component_3_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0.009341 -0.103 0.083713" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/left/Left_Component_3_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="${prefix}motor_3">
  <inertial>
    <origin xyz="-0.0005186558966796062 0.02813050113080831 0.00550509151078743" rpy="0 0 0"/>
    <mass value="0.33655768521614"/>
    <inertia ixx="0.000208" iyy="0.000161" izz="0.000203" ixy="4e-06" iyz="-1.3e-05" ixz="1e-06"/>
  </inertial>
  <visual>
    <origin xyz="0.007241 -0.11298 0.328465" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/left/Left_Motor_3_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0.007241 -0.11298 0.328465" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/left/Left_Motor_3_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="${prefix}component_4">
  <inertial>
    <origin xyz="-0.004872320231196634 0.005488292975636799 -0.08462064279454101" rpy="0 0 0"/>
    <mass value="0.52524072089469"/>
    <inertia ixx="0.001503" iyy="0.00162" izz="0.000292" ixy="-8.6e-05" iyz="7.5e-05" ixz="-3.2e-05"/>
  </inertial>
  <visual>
    <origin xyz="0.00724 -0.115936 0.327953" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/left/Left_Component_4_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0.00724 -0.115936 0.327953" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/left/Left_Component_4_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<joint name="${prefix}revolute_1" type="revolute">
  <origin xyz="-0.093353 0.0 -0.038143" rpy="0 0 0"/>
  <parent link="${arm_base_link}"/>
  <child link="${prefix}motor_1"/>
  <axis xyz="1.0 0.0 0.0"/>
  <dynamics damping="0.012" friction="0.1184"/>
  <limit lower="0" upper="1.919" effort="20" velocity="11"/>
</joint>

<joint name="${prefix}fixed_1" type="fixed">
  <origin xyz="-0.003 0.0 0.0" rpy="0 0 0"/>
  <parent link="${prefix}motor_1"/>
  <child link="${prefix}component_1"/>
</joint>

<joint name="${prefix}fixed_2" type="fixed">
  <origin xyz="0.087 0.107 0.0" rpy="0 0 0"/>
  <parent link="${prefix}component_1"/>
  <child link="${prefix}motor_2"/>
</joint>

<joint name="${prefix}revolute_2" type="revolute">
  <origin xyz="0.0 -0.003 0.0" rpy="0 0 0"/>
  <parent link="${prefix}motor_2"/>
  <child link="${prefix}component_2"/>
  <axis xyz="-0.0 -1.0 0.0"/>
  <dynamics damping="0.012" friction="0.1184"/>
  <limit lower="-0.56" upper="2.793" effort="20" velocity="11"/>
</joint>

<joint name="${prefix}fixed_3" type="fixed">
  <origin xyz="1.2e-05 -0.001 -0.04557" rpy="0 0 0"/>
  <parent link="${prefix}component_2"/>
  <child link="${prefix}component_3"/>
</joint>

<joint name="${prefix}revolute_3" type="revolute">
  <origin xyz="0.0021 0.00998 -0.244752" rpy="0 0 0"/>
  <parent link="${prefix}component_3"/>
  <child link="${prefix}motor_3"/>
  <axis xyz="-7.9e-05 -0.985338 -0.170613"/>
  <dynamics damping="0.012" friction="0.1184"/>
  <limit lower="0" upper="2.094" effort="20" velocity="11"/>
</joint>

<joint name="${prefix}fixed_4" type="fixed">
  <origin xyz="1e-06 0.002956 0.000512" rpy="0 0 0"/>
  <parent link="${prefix}motor_3"/>
  <child link="${prefix}component_4"/>
</joint>

</xacro:macro>
</robot>