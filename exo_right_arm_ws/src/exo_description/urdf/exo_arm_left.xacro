<?xml version="1.0" ?>
<robot name="exo_arm_left" xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:macro name="exo_arm_left" params="prefix mount_x mount_y mount_z mount_roll mount_pitch mount_yaw joint_dynamics:=false
  m_extra_component_1:=0 m_extra_component_2:=0 m_extra_component_3:=0 m_extra_component_4:=0 m_payload:=0
  extra_mass_radius:=0.05">
<xacro:property name="arm_base_link" value="${prefix + 'base_link' if prefix != '' else 'base_link'}"/>
<!-- Each extra mass is modeled as a uniform solid sphere centered at the link's
     existing COM; contribution to ixx/iyy/izz is (2/5)*m*r^2. Off-diagonals are
     unaffected because the sphere is symmetric about the same COM. -->
<xacro:property name="_di_c1" value="${0.4 * m_extra_component_1 * extra_mass_radius * extra_mass_radius}"/>
<xacro:property name="_di_c2" value="${0.4 * m_extra_component_2 * extra_mass_radius * extra_mass_radius}"/>
<xacro:property name="_di_c3" value="${0.4 * m_extra_component_3 * extra_mass_radius * extra_mass_radius}"/>
<xacro:property name="_di_c4" value="${0.4 * (m_extra_component_4 + m_payload) * extra_mass_radius * extra_mass_radius}"/>

<xacro:if value="${prefix != ''}">
  <joint name="${prefix}mount_joint" type="fixed">
    <origin xyz="${mount_x} ${mount_y} ${mount_z}" rpy="${mount_roll} ${mount_pitch} ${mount_yaw}"/>
    <parent link="base_link"/>
    <child link="${arm_base_link}"/>
  </joint>
</xacro:if>

<link name="${arm_base_link}">
  <inertial>
    <origin xyz="-0.06508829102930236 -0.0016392947082375286 -0.029106797642733048" rpy="0 0 0"/>
    <mass value="0.071076"/>
    <inertia ixx="0.000253" iyy="0.00039" izz="0.000225" ixy="-9e-06" iyz="-4e-06" ixz="-0.000127"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/left/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <xacro:if value="${joint_dynamics}">
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/left/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
  </xacro:if>
</link>

<link name="${prefix}motor_1">
  <inertial>
    <origin xyz="-0.028657148535228882 -0.0008037659584219806 0.00012366679922792834" rpy="0 0 0"/>
    <mass value="0.3365576984957861"/>
    <inertia ixx="0.000158" iyy="0.000207" izz="0.000208" ixy="-7e-06" iyz="1e-06" ixz="1e-06"/>
  </inertial>
  <visual>
    <origin xyz="0.094353 -0.00061 0.063136" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/left/Left_Motor_1_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <xacro:if value="${joint_dynamics}">
  <collision>
    <origin xyz="0.094353 -0.00061 0.063136" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/left/Left_Motor_1_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
  </xacro:if>
</link>

<link name="${prefix}component_1">
  <inertial>
    <origin xyz="0.017291080002229037 0.002735639742798342 0.08182000531860147" rpy="0 0 0"/>
    <mass value="${0.13580987071810816 + m_extra_component_1}"/>
    <inertia ixx="${0.000224 + _di_c1}" iyy="${0.000337 + _di_c1}" izz="${0.000165 + _di_c1}" ixy="4e-06" iyz="-2e-06" ixz="-0.000101"/>
  </inertial>
  <visual>
    <origin xyz="0.097353 -0.00061 0.063136" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/left/Left_Component_1_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <xacro:if value="${joint_dynamics}">
  <collision>
    <origin xyz="0.097353 -0.00061 0.063136" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/left/Left_Component_1_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
  </xacro:if>
</link>

<link name="${prefix}motor_2">
  <inertial>
    <origin xyz="9.522009318585489e-05 8.756209107413371e-05 0.025669346895594282" rpy="0 0 0"/>
    <mass value="0.3365576984957861"/>
    <inertia ixx="0.000208" iyy="0.000207" izz="0.000158" ixy="0.0" iyz="5e-06" ixz="-1e-06"/>
  </inertial>
  <visual>
    <origin xyz="0.010353 -0.004345 -0.043799" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/left/Left_Motor_2_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <xacro:if value="${joint_dynamics}">
  <collision>
    <origin xyz="0.010353 -0.004345 -0.043799" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/left/Left_Motor_2_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
  </xacro:if>
</link>

<link name="${prefix}component_2">
  <inertial>
    <origin xyz="0.02130252609513996 -0.06354392139822984 -0.004297968633705511" rpy="0 0 0"/>
    <mass value="${0.06901401596668413 + m_extra_component_2}"/>
    <inertia ixx="${0.000158 + _di_c2}" iyy="${2.6e-05 + _di_c2}" izz="${0.000182 + _di_c2}" ixy="5e-05" iyz="5e-06" ixz="-2e-06"/>
  </inertial>
  <visual>
    <origin xyz="0.010353 -0.00424 -0.040801" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/left/Left_Component_2_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <xacro:if value="${joint_dynamics}">
  <collision>
    <origin xyz="0.010353 -0.00424 -0.040801" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/left/Left_Component_2_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
  </xacro:if>
</link>

<link name="${prefix}component_3">
  <inertial>
    <origin xyz="0.03615700401627118 -0.08448867239925995 -0.008977979556696391" rpy="0 0 0"/>
    <mass value="${0.25726311190565365 + m_extra_component_3}"/>
    <inertia ixx="${0.001177 + _di_c3}" iyy="${0.000369 + _di_c3}" izz="${0.001416 + _di_c3}" ixy="0.0004" iyz="2.1e-05" ixz="3.6e-05"/>
  </inertial>
  <visual>
    <origin xyz="-0.007995 0.050713 -0.030712" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/left/Left_Component_3_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <xacro:if value="${joint_dynamics}">
  <collision>
    <origin xyz="-0.007995 0.050713 -0.030712" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/left/Left_Component_3_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
  </xacro:if>
</link>

<link name="${prefix}motor_3">
  <inertial>
    <origin xyz="-0.0002717727838932593 0.00017757175027499628 0.028666777586146615" rpy="0 0 0"/>
    <mass value="0.3365576984957861"/>
    <inertia ixx="0.000208" iyy="0.000207" izz="0.000158" ixy="-0.0" iyz="5e-06" ixz="2e-06"/>
  </inertial>
  <visual>
    <origin xyz="-0.07979 0.264928 -0.040288" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/left/Left_Motor_3_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <xacro:if value="${joint_dynamics}">
  <collision>
    <origin xyz="-0.07979 0.264928 -0.040288" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/left/Left_Motor_3_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
  </xacro:if>
</link>

<link name="${prefix}component_4">
  <inertial>
    <origin xyz="-0.08439620971621951 0.0033097944704012505 -0.008999385990610932" rpy="0 0 0"/>
    <mass value="${0.07092471532695957 + m_extra_component_4 + m_payload}"/>
    <inertia ixx="${4.2e-05 + _di_c4}" iyy="${0.000201 + _di_c4}" izz="${0.000218 + _di_c4}" ixy="1.3e-05" iyz="-1e-05" ixz="-2.2e-05"/>
  </inertial>
  <visual>
    <origin xyz="-0.079795 0.264831 -0.043287" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/left/Left_Component_4_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <xacro:if value="${joint_dynamics}">
  <collision>
    <origin xyz="-0.079795 0.264831 -0.043287" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://exo_description/meshes/exo_assembly/left/Left_Component_4_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
  </xacro:if>
</link>

<joint name="${prefix}revolute_1" type="revolute">
  <origin xyz="-0.094353 0.00061 -0.063136" rpy="0 0 0"/>
  <parent link="${arm_base_link}"/>
  <child link="${prefix}motor_1"/>
  <axis xyz="1.0 0.0 0.0"/>
  <xacro:if value="${joint_dynamics}">
  <dynamics damping="0.012" friction="0.1184"/>
  </xacro:if>
  <limit lower="-3.14" upper="0" effort="20" velocity="11"/>
</joint>

<joint name="${prefix}fixed_1" type="fixed">
  <origin xyz="-0.003 0.0 0.0" rpy="0 0 0"/>
  <parent link="${prefix}motor_1"/>
  <child link="${prefix}component_1"/>
</joint>

<joint name="${prefix}fixed_2" type="fixed">
  <origin xyz="0.087 0.003735 0.106935" rpy="0 0 0"/>
  <parent link="${prefix}component_1"/>
  <child link="${prefix}motor_2"/>
</joint>

<joint name="${prefix}revolute_2" type="revolute">
  <origin xyz="0.0 -0.000105 -0.002998" rpy="0 0 0"/>
  <parent link="${prefix}motor_2"/>
  <child link="${prefix}component_2"/>
  <axis xyz="0.0 -0.034899 -0.999391"/>
  <xacro:if value="${joint_dynamics}">
  <dynamics damping="0.012" friction="0.1184"/>
  </xacro:if>
  <limit lower="-3.3" upper="0" effort="20" velocity="11"/>
</joint>

<joint name="${prefix}fixed_3" type="fixed">
  <origin xyz="0.018348 -0.054953 -0.010089" rpy="0 0 0"/>
  <parent link="${prefix}component_2"/>
  <child link="${prefix}component_3"/>
</joint>

<joint name="${prefix}revolute_3" type="revolute">
  <origin xyz="0.071795 -0.214215 0.009576" rpy="0 0 0"/>
  <parent link="${prefix}component_3"/>
  <child link="${prefix}motor_3"/>
  <axis xyz="-0.001694 -0.032292 -0.999477"/>
  <xacro:if value="${joint_dynamics}">
  <dynamics damping="0.012" friction="0.1184"/>
  </xacro:if>
  <limit lower="-2.08" upper="0" effort="20" velocity="11"/>
</joint>

<joint name="${prefix}fixed_4" type="fixed">
  <origin xyz="5e-06 9.7e-05 0.002999" rpy="0 0 0"/>
  <parent link="${prefix}motor_3"/>
  <child link="${prefix}component_4"/>
</joint>

</xacro:macro>
</robot>
