<launch>

<rosparam file="$(find LeftArm_description)/launch/controller.yaml" command="load"/>
<node name="controller_spawner" pkg="controller_manager" type="spawner" respawn="false" output="screen" ns="LeftArm" args="Revolute 1_position_controller Revolute 4_position_controller Revolute 8_position_controller joint_state_controller "/>
<node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher" respawn="false" output="screen">
  <remap from="/joint_states" to="/LeftArm/joint_states"/>
</node>

</launch>